---

<section id="servicios" class="py-24 bg-vertex-blue">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-vertex-emerald/30 bg-vertex-emerald/5 text-vertex-emerald text-xs font-semibold tracking-widest uppercase mb-6">
        Nuestros Servicios
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold text-white mb-4">
        Soluciones <span class="text-vertex-gold">integrales</span> para<br/>su organización
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-lg">
        Un ecosistema de servicios especializados diseñado para abordar los desafíos más complejos de la gestión corporativa e institucional.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 auto-rows-auto">
      {sortedServices.map((service, index) => {
        const isLarge = index === 0 || index === 4 || index === 8;
        return (
          <article
            class={`group relative rounded-xl border border-white/10 bg-vertex-blue-light hover:border-vertex-emerald/40 transition-all duration-300 p-6 flex flex-col gap-4 cursor-pointer hover:-translate-y-1 hover:shadow-lg hover:shadow-vertex-emerald/5 ${isLarge ? 'sm:col-span-2' : ''}`}
          >
            <!-- Icon -->
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-vertex-blue flex items-center justify-center text-vertex-emerald border border-vertex-emerald/20 group-hover:bg-vertex-emerald/10 transition-colors">
              <Fragment set:html={iconMap[service.data.icon] ?? iconMap['shield-check']} />
            </div>

            <!-- Order badge -->
            <span class="absolute top-4 right-4 text-xs text-gray-600 font-mono">
              {String(service.data.order).padStart(2, '0')}
            </span>

            <!-- Content -->
            <div class="flex-1">
              <h3 class="text-white font-semibold text-base leading-snug mb-2 group-hover:text-vertex-emerald transition-colors">
                {service.data.title}
              </h3>
              <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">
                {service.body ?? ''}
              </p>
            </div>

            <!-- Arrow indicator -->
            <div class="flex items-center gap-1 text-vertex-gold text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity">
              <span>Ver detalle</span>
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
