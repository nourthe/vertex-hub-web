---
const currentYear = new Date().getFullYear();
---
<footer id="contacto" class="bg-vertex-blue-dark border-t border-white/10">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand column -->
      <div class="md:col-span-2">
        <a href="/" class="inline-block mb-6">
          <img
            src="/logo-placeholder.png"
            alt="Vertex Hub Logo"
            width="48"
            height="48"
            class="h-12 w-12 object-contain"
          />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs mb-6">
          Consultora de ingeniería, tecnología y respaldo jurídico. Transformamos la gestión corporativa e institucional con soluciones integrales y sostenibles.
        </p>
        <div class="flex items-center gap-1 text-vertex-gold text-sm font-semibold">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <a href="mailto:contacto@vertexhub.com" class="hover:text-vertex-gold-light transition-colors">
            contacto@vertexhub.com
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-6">Servicios</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li><a href="#servicios" class="hover:text-vertex-emerald transition-colors">Ciberseguridad</a></li>
          <li><a href="#servicios" class="hover:text-vertex-emerald transition-colors">Ingeniería Eléctrica</a></li>
          <li><a href="#servicios" class="hover:text-vertex-emerald transition-colors">Infraestructura IT</a></li>
          <li><a href="#servicios" class="hover:text-vertex-emerald transition-colors">Inteligencia Artificial</a></li>
          <li><a href="#servicios" class="hover:text-vertex-emerald transition-colors">Consultoría Jurídica</a></li>
          <li><a href="#servicios" class="hover:text-vertex-emerald transition-colors">Vertex Academy</a></li>
        </ul>
      </div>

      <!-- Legal column -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-6">Legal</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li><a href="/privacidad" class="hover:text-vertex-emerald transition-colors">Política de Privacidad</a></li>
          <li><a href="/terminos" class="hover:text-vertex-emerald transition-colors">Términos de Servicio</a></li>
          <li><a href="/cookies" class="hover:text-vertex-emerald transition-colors">Política de Cookies</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-600 text-xs">
        © {currentYear} Vertex Hub. Todos los derechos reservados.
      </p>
      <p class="text-gray-700 text-xs">
        El centro de la gestión eficiente.
      </p>
    </div>
  </div>
</footer>
