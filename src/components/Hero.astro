---
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-vertex-blue-dark">
  <!-- Subtle grid texture -->
  <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(rgba(184,134,11,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(184,134,11,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
  
  <!-- Glow effects -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-vertex-emerald/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-vertex-gold/5 rounded-full blur-3xl"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-vertex-emerald/40 bg-vertex-emerald/10 text-vertex-emerald text-xs font-semibold tracking-widest uppercase mb-8">
      Ingeniería · Tecnología · Respaldo Jurídico
    </div>

    <!-- Main heading -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6">
      El centro de la<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-vertex-gold to-vertex-gold-light">gestión eficiente</span>
    </h1>

    <!-- Subheading -->
    <p class="text-xl text-gray-400 max-w-3xl mx-auto mb-12 leading-relaxed">
      Vertex Hub integra ingeniería, tecnología e inteligencia jurídica para transformar las operaciones de empresas e instituciones en soluciones concretas y sostenibles.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#servicios"
        class="group inline-flex items-center gap-2 bg-vertex-gold hover:bg-vertex-gold-light text-white font-semibold px-8 py-4 rounded transition-all duration-200 text-base shadow-lg shadow-vertex-gold/20"
      >
        Explorar Servicios
        <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 border border-gray-600 hover:border-vertex-emerald text-gray-300 hover:text-vertex-emerald font-semibold px-8 py-4 rounded transition-all duration-200 text-base"
      >
        Agendar Consulta
      </a>
    </div>

    <!-- Stats row -->
    <div class="mt-20 grid grid-cols-3 gap-8 border-t border-white/10 pt-12">
      <div>
        <div class="text-3xl font-bold text-vertex-gold">11+</div>
        <div class="text-sm text-gray-500 mt-1">Áreas de Servicio</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-vertex-gold">B2B</div>
        <div class="text-sm text-gray-500 mt-1">Enfoque Corporativo</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-vertex-gold">360°</div>
        <div class="text-sm text-gray-500 mt-1">Soluciones Integrales</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div 
    id="scroll-indicator" 
    class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-gray-500/60 transition-opacity duration-300 z-20 pointer-events-none"
  >
    <span class="text-[10px] tracking-[0.2em] uppercase hidden sm:block">Scroll</span>
    <svg class="h-5 w-5 animate-bounce-slow" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(-25%); animation-timing-function: cubic-bezier(0.8, 0, 1, 1); }
    50% { transform: translateY(0); animation-timing-function: cubic-bezier(0, 0, 0.2, 1); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 2s infinite;
  }
</style>

<script>
  const indicator = document.getElementById('scroll-indicator');
  if (indicator) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        indicator.style.opacity = '0';
      } else {
        indicator.style.opacity = '1';
      }
    }, { passive: true });
  }
</script>
